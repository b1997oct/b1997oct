---
import { Dashboard as DashboardView } from "../components/Dashboard";
import "../styles/global.css";

const siteOrigin = Astro.url.origin;
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const ogImageURL = new URL("/logo.png", siteOrigin);
const pageTitle = "Dashboard | Agent_B7";
const pageDescription =
	"Public analytics for Agent_B7: session counts, message volume, and guest chat activity. Built for transparency and monitoring.";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="canonical" href={canonicalURL.href} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<link rel="apple-touch-icon" href="/logo.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)" />
		<meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<meta
			name="keywords"
			content="Agent_B7, Dashboard, Analytics, AI Agent, Sessions, Chat metrics"
		/>
		<meta name="author" content="Barath" />
		<meta name="robots" content="index, follow" />

		<meta property="og:site_name" content="Agent_B7" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:locale" content="en_US" />
		<meta property="og:image" content={ogImageURL.href} />
		<meta property="og:image:type" content="image/png" />
		<meta
			property="og:image:alt"
			content="Agent_B7 logo — vibrant gradient four-pointed star on a dark background"
		/>

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={ogImageURL.href} />
		<script is:inline>
			const stored = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
			const resolved =
				stored === 'light' || stored === 'dark'
					? stored
					: window.matchMedia('(prefers-color-scheme: dark)').matches
						? 'dark'
						: 'light';

			document.documentElement.classList.toggle('dark', resolved === 'dark');
			if (stored === 'light' || stored === 'dark') {
				window.localStorage.setItem('theme', resolved);
			}
		</script>
	</head>
	<body class="bg-slate-50 dark:bg-slate-950 min-h-screen transition-colors duration-300">
		<DashboardView client:load />
	</body>
</html>
